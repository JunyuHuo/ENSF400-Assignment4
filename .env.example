# === Required ===

# PostgreSQL database (Render or any provider)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# === OVH AI (GPT-OSS-120b) — for personalized recommendations ===
OVH_AI_API_KEY="your_ovh_ai_key_here"
OVH_AI_MODEL="gpt-oss-120b"
OVH_AI_BASE_URL="https://oai.endpoints.kepler.ai.cloud.ovh.net/v1"

# === OpenAI (fallback alternative) ===
# Only needed if OVH_AI_API_KEY is not set
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4.1-mini"
